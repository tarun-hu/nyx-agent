# pyenv
#   For a library or app, you might want to share this in the version control.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a multi-platform environment, it may be useful to ignore.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally committed, but can be ignored if needed.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally committed, but can be ignored if needed.
#pdm.lock

# PEP 582; project local packages directory (used by pdm)
__pypackages__/

